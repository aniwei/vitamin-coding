{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "ignorePatterns": ["packages/cli", "**/*.test.ts", "**/*.spec.ts"],
  "useTabs": false,
  "tabWidth": 2,
  "printWidth": 100,
  "singleQuote": true,
  "jsxSingleQuote": true,
  "semi": false,
  "trailingComma": "all",
  "arrowParens": "always"
}
