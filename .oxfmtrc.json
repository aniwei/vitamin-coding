{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "ignorePatterns": [
    "**/*.test.ts",
    "**/*.spec.ts",
    "packages/cli/**",
    "packages/web-ui/**",
    "packages/opendev-ui/**"
  ],
  "useTabs": false,
  "tabWidth": 2,
  "printWidth": 100,
  "singleQuote": true,
  "jsxSingleQuote": true,
  "semi": false,
  "trailingComma": "all",
  "arrowParens": "always"
}
