{
  "name": "@vitamin/ai",
  "version": "0.0.1",
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "build": "tsdown",
    "typecheck:project": "tsc -p tsconfig.json --noEmit",
    "typecheck:file": "tsc src/index.ts --noEmit --target ES2024 --module ESNext --moduleResolution bundler --esModuleInterop --skipLibCheck",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "generate:models": "tsx scripts/generate-models.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.88.0",
    "@vitamin/env": "workspace:*",
    "@vitamin/shared": "workspace:*",
    "eventsource-parser": "3.0.6",
    "zod": "4.3.6"
  }
}
