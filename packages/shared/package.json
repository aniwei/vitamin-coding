{
  "name": "@vitamin/shared",
  "version": "0.0.1",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck:project": "tsc -p tsconfig.json --noEmit",
    "typecheck:file": "tsc src/index.ts --noEmit --target ES2024 --module ESNext --moduleResolution bundler --esModuleInterop --skipLibCheck",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@vitamin/invariant": "workspace:*",
    "@vitamin/env": "workspace:*",
    "eventsource-parser": "^3.0.6",
    "jsonc-parser": "^3.3.1",
    "mime-types": "^3.0.2",
    "pino": "^9.6.0",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.0",
    "remark-parse": "^11.0.0",
    "safe-stable-stringify": "^2.5.0",
    "unified": "^11.0.0",
    "uuid": "^13.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "devDependencies": {
    "@types/mime-types": "^3.0.1",
    "@types/node": "^25.3.5"
  }
}
