{
  "name": "@x-mars/shared",
  "version": "0.0.1",
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./browser": {
      "types": "./dist/browser/index.d.ts",
      "import": "./dist/browser/index.js"
    },
    "./browser/event-emitter": {
      "types": "./dist/browser/event-emitter.d.ts",
      "import": "./dist/browser/event-emitter.js"
    },
    "./browser/subscription": {
      "types": "./dist/browser/subscription.d.ts",
      "import": "./dist/browser/subscription.js"
    },
    "./browser/data": {
      "types": "./dist/browser/data.d.ts",
      "import": "./dist/browser/data.js"
    },
    "./runtime": {
      "types": "./dist/runtime.d.ts",
      "import": "./dist/runtime.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "build": "tsdown",
    "typecheck:project": "tsc -p tsconfig.json --noEmit",
    "typecheck:file": "tsc src/index.ts --noEmit --target ES2024 --module ESNext --moduleResolution bundler --esModuleInterop --skipLibCheck",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@x-mars/env": "workspace:*",
    "@x-mars/invariant": "workspace:*",
    "eventsource-parser": "3.0.6",
    "jsonc-parser": "3.3.1",
    "mime-types": "3.0.2",
    "pino": "10.3.1",
    "pino-pretty": "13.1.3",
    "remark-frontmatter": "5.0.0",
    "remark-gfm": "4.0.1",
    "remark-parse": "11.0.0",
    "safe-stable-stringify": "2.5.0",
    "unified": "11.0.5",
    "uuid": "13.0.0"
  },
  "devDependencies": {
    "@types/mime-types": "3.0.1"
  }
}
