{
  "$schema": "https://raw.githubusercontent.com/oxc-project/oxc/main/npm/oxlint/configuration_schema.json",
  "env": {
    "browser": true,
    "es2022": true,
    "node": true
  },
  "globals": {},
  "rules": {
    "no-unused-vars": "error",
    "no-var": "error",
    "prefer-const": "error",
    "no-extra-boolean-cast": "warn"
  },
  "overrides": [
    {
      "files": ["*.ts", "*.tsx", "*.mts", "*.cts"],
      "rules": {
        "no-unused-vars": "error"
      }
    }
  ]
}
