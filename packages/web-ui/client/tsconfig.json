{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "typeRoots": [
      "../node_modules/@types",
      "../../../node_modules/@types",
      "../node_modules"
    ],
    "types": ["vite/client"],
    "paths": {
      "@/*": ["src/*"],
      "ai": ["../node_modules/ai/dist/index.d.ts"],
      "@ai-sdk/react": ["../node_modules/@ai-sdk/react/dist/index.d.ts"],
      "@vercel/blob/client": ["../node_modules/@vercel/blob/dist/client.d.ts"]
    }
  },
  "include": ["src", "vite.config.ts"],
  "compileOnSave": false
}
