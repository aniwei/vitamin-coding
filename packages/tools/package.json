{
  "name": "@vitamin/tools",
  "version": "0.0.1",
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "build": "tsdown",
    "typecheck:project": "tsc -p tsconfig.json --noEmit",
    "typecheck:file": "tsc src/index.ts --noEmit --target ES2024 --module ESNext --moduleResolution bundler --esModuleInterop --skipLibCheck",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@vitamin/agent": "workspace:*",
    "@vitamin/ai": "workspace:*",
    "@vitamin/env": "workspace:*",
    "@vitamin/hooks": "workspace:*",
    "@vitamin/invariant": "workspace:*",
    "@vitamin/mcp": "workspace:*",
    "@vitamin/setting": "workspace:*",
    "@vitamin/shared": "workspace:*",
    "chalk": "5.6.2",
    "diff": "8.0.4",
    "yaml": "2.8.3",
    "zod": "4.3.6"
  }
}
