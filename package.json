{
  "name": "vitamin-coding",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "build": "turbo run build",
    "build:schema": "tsx scripts/build-schema.ts",
    "docs:check-package-sync": "tsx scripts/check-doc-package-sync.ts",
    "quality:check-type-safety": "tsx scripts/check-type-safety-guards.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "turbo run typecheck",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "clean": "turbo run clean && rm -rf node_modules",
    "prepublish:check": "pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "version:bump": "tsx scripts/version-bump.ts",
    "publish:packages": "turbo run build && pnpm -r publish --access public --no-git-checks"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^25.3.2",
    "@vitest/coverage-v8": "^3.0.5",
    "tsup": "^8.3.6",
    "tsx": "^4.19.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5",
    "zod": "^4.0.0",
    "zod-to-json-schema": "^3.24.6"
  }
}
