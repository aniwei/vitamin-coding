{
  "name": "vitamin-coding",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nx run-many -t build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "nx run-many -t typecheck",
    "lint": "oxlint && oxfmt --check",
    "lint:fix": "oxlint --fix && oxfmt",
    "format": "oxfmt",
    "clean": "nx reset && find packages -name dist -type d -exec rm -rf {} +",
    "prepublish:check": "pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "publish:packages": "nx run-many -t build && pnpm -r publish --access public --no-git-checks",
    "dev:service": "tsx packages/service/example/devtools-service.ts",
    "dev:web-ui": "pnpm --filter @vitamin/web-ui dev",
    "dev": "pnpm dev:service & pnpm dev:web-ui"
  },
  "devDependencies": {
    "@types/node": "25.5.2",
    "@vitest/coverage-v8": "4.1.3",
    "nx": "22.6.4",
    "oxfmt": "0.44.0",
    "oxlint": "1.59.0",
    "tsdown": "0.21.7",
    "tsx": "4.21.0",
    "typescript": "6.0.2",
    "vitest": "4.1.3",
    "zod": "4.3.6",
    "zod-to-json-schema": "3.25.2"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@9.15.4"
}
